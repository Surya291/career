{
    "latex-workshop.latex.env": {
      "PATH": "/Library/TeX/texbin:/usr/bin:/bin:/usr/sbin:/sbin"
    },
    "latex-workshop.latex.tools": [
      {
        "name": "pdflatex-abs",
        "command": "/Library/TeX/texbin/pdflatex",
        "args": [
          "-synctex=1",
          "-interaction=nonstopmode",
          "-file-line-error",
          "%DOC%"
        ]
      }
    ],
    "latex-workshop.latex.recipes": [
      {
        "name": "pdflatex (fast)",
        "tools": ["pdflatex-abs"]
      }
    ],
    "latex-workshop.latex.recipe.default": "pdflatex (fast)",
    "latex-workshop.latex.autoBuild.run": "onSave"
  }